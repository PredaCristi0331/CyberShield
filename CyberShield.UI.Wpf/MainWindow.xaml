<Window x:Class="CyberShield.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:viewmodels="clr-namespace:CyberShield.Presentation.ViewModels;assembly=CyberShield.Presentation" d:DataContext="{d:DesignInstance Type=viewmodels:ScanViewModel}"
        mc:Ignorable="d"
        Title="CyberShield Deepfake Detector"
        Width="1200" Height="760"
        MinWidth="1080" MinHeight="700"
        Background="#0F0F10"
        Foreground="#EAEAEA"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave">

    <Window.Resources>

        <!-- Accent -->
        <Color x:Key="AccentColor">#FF4CC2FF</Color>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentBrushSoft" Color="#334CC2FF"/>

        <!-- Surfaces -->
        <SolidColorBrush x:Key="SurfaceBrush" Color="#151518"/>
        <SolidColorBrush x:Key="SurfaceBrush2" Color="#1B1B20"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#B8B8B8"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FFFF4D4D"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF2AD27B"/>

        <!-- Typography -->
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        </Style>

        <!-- Card -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Buttons -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#0B0B0C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush2}"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <FontFamily x:Key="FluentIconFont">Segoe Fluent Icons</FontFamily>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            
        </Grid.RowDefinitions>

        
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                
                <Border Width="36" Height="36" CornerRadius="10" Background="{StaticResource AccentBrushSoft}">
                    <TextBlock Text=""
                               FontFamily="{StaticResource FluentIconFont}"
                               FontSize="18"
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Vertical">
                    <TextBlock Style="{StaticResource TitleText}" Text="CyberShield Deepfake Detector"/>
                    <TextBlock Style="{StaticResource MutedText}" Text="{Binding StatusText}" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OpenFile_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="" FontFamily="{StaticResource FluentIconFont}" Margin="0,0,8,0"/>
                            <TextBlock Text="Open"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Command="{Binding StartScanCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="" FontFamily="{StaticResource FluentIconFont}" Margin="0,0,8,0"/>
                            <TextBlock Text="Scan"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="" FontFamily="{StaticResource FluentIconFont}" Margin="0,0,8,0"/>
                            <TextBlock Text="Stop"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="360"/>
                
            </Grid.ColumnDefinitions>

            
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Input" FontSize="14" FontWeight="SemiBold"/>

                    
                    <Border Grid.Row="2"
                            x:Name="DropZone"
                            Background="{StaticResource SurfaceBrush2}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="" FontFamily="{StaticResource FluentIconFont}" FontSize="34"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Drag and drop a video here" FontWeight="SemiBold"
                                       Margin="0,10,0,2" HorizontalAlignment="Center"/>
                            <TextBlock Style="{StaticResource MutedText}" Text="Or click Open. MP4 / MKV / MOV"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Style="{StaticResource MutedText}"
                                       Text="{Binding FilePath, StringFormat=Selected: {0}}"/>
                        </StackPanel>
                    </Border>

                    
                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Scan options" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush2}" CornerRadius="10" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Sampling FPS" FontWeight="SemiBold"/>
                                    <TextBlock Style="{StaticResource MutedText}" Text="10 fps (default)"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush2}" CornerRadius="10" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Batch size" FontWeight="SemiBold"/>
                                    <TextBlock Style="{StaticResource MutedText}" Text="16 (default)"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="{StaticResource SurfaceBrush2}" CornerRadius="10" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Performance" FontWeight="SemiBold"/>
                                <TextBlock Style="{StaticResource MutedText}"
                                           Text="Runs in background. UI stays responsive."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Preview" FontSize="14" FontWeight="SemiBold"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Play_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="" FontFamily="{StaticResource FluentIconFont}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Play"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Pause_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="" FontFamily="{StaticResource FluentIconFont}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Pause"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Click="Stop_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="" FontFamily="{StaticResource FluentIconFont}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Stop"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" Background="#0B0B0C" CornerRadius="12" ClipToBounds="True">
                        <Grid>
                            <MediaElement Name="Player"
                                          Source="{Binding FilePath}"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Manual"
                                          Stretch="Uniform"/>

                            
                            <Image Source="{Binding OverlayBitmap}"
                                   Stretch="Uniform"
                                   IsHitTestVisible="False"
                                   Opacity="0.55"/>

                            
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Margin="12" Padding="10,6"
                                    Background="#99000000"
                                    CornerRadius="10"
                                    BorderBrush="#33FFFFFF" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Score:" Style="{StaticResource MutedText}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding OverallScore, StringFormat={}{0:0.000}}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Style="{StaticResource MutedText}"
                                   Text="Tip: Drop a file, press Scan, export report when done."/>
                        <TextBlock Grid.Column="2" Style="{StaticResource MutedText}"
                                   Text="{Binding ProgressPercent, StringFormat=Progress: {0:0}%}"/>
                    </Grid>
                </Grid>
            </Border>

            
            <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Results" FontSize="14" FontWeight="SemiBold"/>

                    <Border Grid.Row="2" Background="{StaticResource SurfaceBrush2}" CornerRadius="12" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Overall verdict" FontWeight="SemiBold"/>

                            
                            <TextBlock Text="{Binding VerdictText}" 
               Foreground="{Binding VerdictColor}" 
               FontWeight="Bold" 
               FontSize="16" 
               Margin="0,4,0,0"/>

                            <TextBlock Style="{StaticResource MutedText}" Text="Probability of manipulation (0..1)"/>
                            <ProgressBar Height="14" Margin="0,10,0,0"
                 Minimum="0" Maximum="1"
                 Value="{Binding OverallScore}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4" Background="{StaticResource SurfaceBrush2}" CornerRadius="12" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Report" FontWeight="SemiBold"/>
                            <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap"
                                       Text="{Binding ReportPath, TargetNullValue=No report generated yet.}"/>
                            <Button Style="{StaticResource SecondaryButton}" Margin="0,10,0,0"
                                    Click="OpenReport_Click"
                                    IsEnabled="{Binding ReportPath, Converter={StaticResource NullToBoolConverter}, FallbackValue=False}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="" FontFamily="{StaticResource FluentIconFont}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Open report"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="6" Background="{StaticResource SurfaceBrush2}" CornerRadius="12" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Diagnostics" FontWeight="SemiBold"/>
                            <TextBlock Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap"
                                       Text="Decode → preprocess → inference → persist → report. Add per-stage timings in v2."/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        
        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Risk timeline" FontWeight="SemiBold" VerticalAlignment="Center"/>

                
                <Border Grid.Column="2" Background="{StaticResource SurfaceBrush2}" CornerRadius="10" Padding="10">
                    <Grid>
                        <Rectangle Height="10" RadiusX="6" RadiusY="6" Fill="#1F1F24" VerticalAlignment="Center"/>
                        
                        <Rectangle Height="10" RadiusX="6" RadiusY="6"
                                   Fill="{StaticResource AccentBrushSoft}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Grid.Column="4"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           Text="Green→Safe | Red→Suspicious"/>
            </Grid>
        </Border>

    </Grid>
</Window>